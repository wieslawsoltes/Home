---
import '@/styles/global.css';
import SiteSearch from '@/components/SiteSearch.astro';
import { ClientRouter, fade } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  pageType?: 'WebPage' | 'AboutPage' | 'CollectionPage' | 'ProfilePage';
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'Wiesław Šoltés — Open-source .NET systems',
  description = 'Open-source UI frameworks, GPU rendering, controls, and developer tools by Wiesław Šoltés.',
  image,
  imageAlt,
  pageType = 'WebPage',
  structuredData = []
} = Astro.props;
const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, Astro.site);
const home = new URL(base, Astro.site);
const sitemap = new URL(`${base}sitemap.xml`, Astro.site);
const pageTitle = title.includes('Wiesław') ? title : `${title} — Wiesław Šoltés`;
const openGraphType = pageType === 'AboutPage' || pageType === 'ProfilePage' ? 'profile' : 'website';
const imageUrl = image
  ? new URL(image.match(/^https?:\/\//) ? image : image.replace(/^\//, ''), image.match(/^https?:\/\//) ? undefined : home).href
  : undefined;
const personId = `${home.href}#person`;
const websiteId = `${home.href}#website`;
const pageId = `${canonical.href}#webpage`;
const extraStructuredData = Array.isArray(structuredData) ? structuredData : [structuredData];
const primaryEntity = extraStructuredData.find((item) => typeof item['@id'] === 'string')?.['@id'];
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': personId,
      name: 'Wiesław Šoltés',
      url: home.href,
      jobTitle: 'Independent open-source software engineer',
      sameAs: ['https://github.com/wieslawsoltes'],
      knowsAbout: ['.NET', 'Avalonia', 'Uno Platform', 'WPF', 'WinForms', 'XAML', 'GPU rendering', 'developer tools']
    },
    {
      '@type': 'WebSite',
      '@id': websiteId,
      url: home.href,
      name: 'Wiesław Šoltés — Open-source .NET systems',
      description: 'Open-source UI frameworks, GPU rendering, controls, and developer tools by Wiesław Šoltés.',
      inLanguage: 'en',
      publisher: { '@id': personId }
    },
    {
      '@type': pageType,
      '@id': pageId,
      url: canonical.href,
      name: pageTitle,
      description,
      inLanguage: 'en',
      isPartOf: { '@id': websiteId },
      about: { '@id': personId },
      ...(primaryEntity ? { mainEntity: { '@id': primaryEntity } } : {}),
      ...(imageUrl ? { primaryImageOfPage: { '@type': 'ImageObject', url: imageUrl } } : {})
    },
    ...extraStructuredData
  ]
}).replaceAll('<', '\\u003c');
---

<!doctype html>
<html lang="en" data-base={base} transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#08090c" />
    <meta name="color-scheme" content="dark" />
    <meta name="description" content={description} />
    <meta name="author" content="Wiesław Šoltés" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta property="og:type" content={openGraphType} />
    <meta property="og:site_name" content="Wiesław Šoltés" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {openGraphType === 'profile' && <meta property="profile:first_name" content="Wiesław" />}
    {openGraphType === 'profile' && <meta property="profile:last_name" content="Šoltés" />}
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    {imageUrl?.startsWith('https://') && <meta property="og:image:secure_url" content={imageUrl} />}
    {imageUrl && imageAlt && <meta property="og:image:alt" content={imageAlt} />}
    <meta name="twitter:card" content={imageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    {imageUrl && imageAlt && <meta name="twitter:image:alt" content={imageAlt} />}
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" type="application/xml" href={sitemap} />
    <link rel="me" href="https://github.com/wieslawsoltes" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <script type="application/ld+json" set:html={jsonLd} is:inline />
    <slot name="head" />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="ambient-glow" aria-hidden="true" transition:name="ambient-glow" transition:persist transition:animate="none"></div>
    <header class="site-header" data-header transition:name="site-header" transition:persist transition:animate="none">
      <a class="wordmark" href={base} aria-label="Wiesław Šoltés, home">
        <span class="wordmark-mark" aria-hidden="true">W<span>/</span>S</span>
        <span class="wordmark-name">Wiesław Šoltés</span>
      </a>
      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
        <span>Menu</span><i aria-hidden="true"></i>
      </button>
      <nav class="site-nav" id="site-nav" aria-label="Primary navigation">
        <a href={`${base}#work`}>Work</a>
        <a href={`${base}ecosystem/`}>Ecosystem</a>
        <a href={`${base}now/`}>Now</a>
        <a href={`${base}about/`}>About</a>
        <a href={`${base}#contact`}>Contact</a>
        <button class="nav-search" type="button" data-search-open aria-haspopup="dialog" aria-controls="site-search-dialog" aria-keyshortcuts="Meta+K Control+K">
          <svg viewBox="0 0 20 20" aria-hidden="true"><circle cx="8.5" cy="8.5" r="5"></circle><path d="m12.3 12.3 4 4"></path></svg>
          Search <kbd data-search-shortcut>⌘K</kbd>
        </button>
        <a class="nav-github" href="https://github.com/wieslawsoltes" target="_blank" rel="noreferrer">
          GitHub <span aria-hidden="true">↗</span>
        </a>
      </nav>
    </header>
    <main id="main" transition:name="page-content" transition:animate={fade({ duration: '220ms' })}>
      <slot />
    </main>
    <footer class="site-footer" id="contact" transition:name="site-footer" transition:animate="none">
      <div class="footer-lead" data-reveal>
        <p class="section-label">Open source is a long conversation.</p>
        <h2>Let’s build the next useful thing.</h2>
      </div>
      <div class="footer-links" data-reveal>
        <a href="https://github.com/wieslawsoltes" target="_blank" rel="noreferrer">GitHub <span>↗</span></a>
        <a href="https://github.com/sponsors/wieslawsoltes" target="_blank" rel="noreferrer">Sponsor <span>↗</span></a>
      </div>
      <div class="footer-meta">
        <p>Wiesław Šoltés · Poland</p>
        <p>Built for the open web · <span data-year></span></p>
      </div>
    </footer>
    <SiteSearch />

    <script>
      import '@/scripts/site';
    </script>
  </body>
</html>
