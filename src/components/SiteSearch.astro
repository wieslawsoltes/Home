<dialog class="site-search-dialog" id="site-search-dialog" data-site-search aria-labelledby="site-search-title">
  <div class="site-search-panel">
    <header class="site-search-header">
      <div class="site-search-heading">
        <p class="section-label">Navigate the ecosystem</p>
        <h2 id="site-search-title">Search everything.</h2>
      </div>
      <button class="site-search-close" type="button" data-search-close aria-label="Close search">
        <span>Close</span><i aria-hidden="true"></i>
      </button>
    </header>

    <form class="site-search-form" role="search" data-search-form>
      <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="10.5" cy="10.5" r="6.5"></circle><path d="m15.5 15.5 5 5"></path></svg>
      <label class="sr-only" for="site-search-input">Search projects, capabilities, packages, and pages</label>
      <input
        id="site-search-input"
        type="search"
        placeholder="Try “SVG animation”, “Uno”, or a NuGet package…"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        enterkeyhint="go"
        data-search-input
      />
      <kbd data-search-shortcut>⌘K</kbd>
    </form>

    <div class="site-search-status">
      <p aria-live="polite" aria-atomic="true" data-search-summary>Loading the index…</p>
      <p><kbd>↑</kbd><kbd>↓</kbd> move <kbd>↵</kbd> open <kbd>esc</kbd> close</p>
    </div>

    <div class="site-search-content">
      <p class="site-search-message" data-search-message>Preparing projects and capabilities…</p>
      <ol class="site-search-results" data-search-results aria-label="Search results"></ol>
    </div>

    <footer class="site-search-footer">
      <span>Projects</span><i></i><span>Capabilities</span><i></i><span>Packages</span><i></i><span>Pages</span>
    </footer>
  </div>
</dialog>
