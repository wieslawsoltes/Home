---
interface StoryStep {
  label: string;
  detail: string;
  signal: string;
  href: string;
}

interface Props {
  label: string;
  steps: StoryStep[];
}

const { label, steps } = Astro.props;
---

<div class="story-flow" data-reveal>
  <p>{label}</p>
  <ol aria-label={label}>
    {steps.map((step, index) => (
      <li>
        <a href={step.href}>
          <span>{String(index + 1).padStart(2, '0')} · {step.signal}</span>
          <h3>{step.label}</h3>
          <p>{step.detail}</p>
          <i aria-hidden="true">↗</i>
        </a>
      </li>
    ))}
  </ol>
</div>

<style>
  .story-flow > p {
    margin: 0 0 18px;
    color: var(--faint);
    font: 9px/1 ui-monospace, monospace;
    letter-spacing: .13em;
    text-transform: uppercase;
  }

  ol {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    list-style: none;
  }

  li {
    min-width: 0;
    border-right: 1px solid var(--line);
    transition: opacity .25s ease;
  }

  li:last-child {
    border-right: 0;
  }

  ol:hover li:not(:hover),
  ol:focus-within li:not(:focus-within) {
    opacity: .46;
  }

  a {
    position: relative;
    display: flex;
    min-height: 275px;
    padding: 26px 28px 30px;
    flex-direction: column;
    background: transparent;
    transition: background .25s ease, transform .25s ease;
  }

  a:hover,
  a:focus-visible {
    background: color-mix(in srgb, var(--project-accent) 7%, transparent);
    transform: translateY(-5px);
    outline: none;
  }

  a:focus-visible::after {
    content: '';
    position: absolute;
    inset: 5px;
    border: 1px solid var(--project-accent);
  }

  a > span {
    color: var(--project-accent);
    font: 9px/1 ui-monospace, monospace;
    letter-spacing: .1em;
    text-transform: uppercase;
  }

  h3 {
    margin: auto 0 15px;
    font-size: clamp(24px, 2.4vw, 36px);
    font-weight: 540;
    line-height: 1;
    letter-spacing: -.045em;
  }

  a > p {
    margin: 0;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.65;
  }

  i {
    position: absolute;
    top: 24px;
    right: 26px;
    color: var(--project-accent);
    font-style: normal;
    opacity: .5;
    transition: opacity .2s ease, transform .2s ease;
  }

  a:hover i,
  a:focus-visible i {
    opacity: 1;
    transform: translate(3px, -3px);
  }

  @media (max-width: 980px) {
    ol {
      grid-template-columns: 1fr 1fr;
    }

    li:nth-child(2) {
      border-right: 0;
    }

    li:nth-child(n + 3) {
      border-top: 1px solid var(--line);
    }
  }

  @media (max-width: 700px) {
    ol {
      grid-template-columns: 1fr;
    }

    li,
    li:nth-child(2) {
      border-top: 1px solid var(--line);
      border-right: 0;
    }

    li:first-child {
      border-top: 0;
    }

    a {
      min-height: 220px;
      padding-inline: 0;
    }

    a:hover,
    a:focus-visible {
      padding-inline: 18px;
      transform: none;
    }
  }
</style>
