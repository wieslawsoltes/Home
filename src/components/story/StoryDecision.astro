---
interface Props {
  label: string;
  title: string;
}

const { label, title } = Astro.props;
---

<aside class="story-decision" data-reveal>
  <p class="story-decision-label">{label}</p>
  <div>
    <h3>{title}</h3>
    <div class="story-decision-copy"><slot /></div>
  </div>
</aside>

<style>
  .story-decision {
    display: grid;
    grid-template-columns: .5fr 2fr;
    gap: 7%;
    padding: 54px 0 58px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--project-accent) 5%, transparent), transparent);
  }

  .story-decision-label {
    margin: 5px 0 0;
    color: var(--project-accent);
    font: 9px/1 ui-monospace, monospace;
    letter-spacing: .13em;
    text-transform: uppercase;
  }

  h3 {
    max-width: 900px;
    margin: 0;
    font-size: clamp(34px, 4vw, 60px);
    font-weight: 540;
    line-height: 1.05;
    letter-spacing: -.05em;
  }

  .story-decision-copy {
    max-width: 730px;
    margin-top: 28px;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.75;
  }

  .story-decision-copy :global(p) {
    margin: 0;
  }

  .story-decision-copy :global(strong) {
    color: var(--text);
    font-weight: 560;
  }

  @media (max-width: 980px) {
    .story-decision {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }

  @media (max-width: 700px) {
    .story-decision {
      padding: 40px 0 44px;
    }

    h3 {
      font-size: 36px;
    }
  }
</style>
