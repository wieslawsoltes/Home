---
import ProjectGlyph from './ProjectGlyph.astro';
import { getProjects, projectUrl } from '@/lib/content';

const base = import.meta.env.BASE_URL;
const projects = await getProjects();
const visibleProjects = projects.filter((project) => project.showInIndex !== false);
const categories = ['All', 'Graphics', 'Frameworks', 'Avalonia', 'Uno Platform', 'Controls', 'Tools'];
---

<section class="project-index section-shell" id="work" data-project-index>
  <div class="section-heading" data-reveal>
    <p class="section-label">Selected systems · 01—{String(visibleProjects.length).padStart(2, '0')}</p>
    <h2>Work that compounds.</h2>
    <p>Frameworks, graphics, controls, and tools maintained as parts of a larger open-source ecosystem.</p>
  </div>

  <div class="project-tools" data-reveal>
    <div class="project-filters" role="group" aria-label="Filter projects by category">
      {categories.map((category) => (
        <button type="button" class="filter-button" data-filter={category} aria-pressed={category === 'All' ? 'true' : 'false'}>
          {category}
        </button>
      ))}
    </div>
    <label class="project-search">
      <span class="sr-only">Search projects</span>
      <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="6.5"></circle><path d="m16 16 5 5"></path></svg>
      <input type="search" placeholder="Search the archive" autocomplete="off" data-project-search />
    </label>
  </div>

  <div class="project-list" data-project-list>
    {visibleProjects.map((project, index) => (
      <a
        class="project-row"
        href={projectUrl(project, base)}
        data-project
        data-category={project.category}
        data-search={`${project.name} ${project.description} ${project.category}`.toLowerCase()}
        data-reveal
        style={`--project-accent:${project.accent};--delay:${Math.min(index * 28, 240)}ms`}
      >
        <span class="project-number">{String(index + 1).padStart(2, '0')}</span>
        <span class="project-primary">
          <strong data-transition-title={`project-title-${project.slug}`}>{project.name}</strong>
          <small>{project.tier} · {project.eyebrow}</small>
        </span>
        <span class="project-category">{project.category}</span>
        <span class="project-description">{project.description}</span>
        <span class="project-arrow" aria-hidden="true">↗</span>
        <span class="project-preview" aria-hidden="true"><ProjectGlyph slug={project.slug} accent={project.accent} /></span>
      </a>
    ))}
  </div>
  <p class="empty-projects" hidden data-empty>No projects match that search.</p>
</section>
