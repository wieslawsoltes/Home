---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectIndex from '@/components/ProjectIndex.astro';
import ProjectGlyph from '@/components/ProjectGlyph.astro';
import SystemsMap from '@/components/SystemsMap.astro';
import ArchiveIndex from '@/components/ArchiveIndex.astro';
import { featuredProjects, projectUrl } from '@/data/projects';

const base = import.meta.env.BASE_URL;
const proEdit = featuredProjects.find((project) => project.slug === 'proedit');
const spotlights = [...featuredProjects.slice(0, 4), ...(proEdit ? [proEdit] : [])];
---

<BaseLayout>
  <section class="home-hero" aria-labelledby="hero-title">
    <div class="hero-art" aria-hidden="true">
      <svg viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
        <defs>
          <radialGradient id="hero-orb" cx="50%" cy="50%" r="50%">
            <stop stop-color="#8ea2ff" stop-opacity=".88" />
            <stop offset=".5" stop-color="#5269db" stop-opacity=".18" />
            <stop offset="1" stop-color="#08090c" stop-opacity="0" />
          </radialGradient>
          <linearGradient id="hero-line" x1="0" y1="0" x2="1" y2="1">
            <stop stop-color="#a9b6ff" stop-opacity=".8" />
            <stop offset="1" stop-color="#a9b6ff" stop-opacity=".04" />
          </linearGradient>
        </defs>
        <g class="hero-grid">
          <path d="M0 100h1440M0 200h1440M0 300h1440M0 400h1440M0 500h1440M0 600h1440M0 700h1440M0 800h1440" />
          <path d="M120 0v900M240 0v900M360 0v900M480 0v900M600 0v900M720 0v900M840 0v900M960 0v900M1080 0v900M1200 0v900M1320 0v900" />
        </g>
        <circle class="hero-orb" cx="1050" cy="432" r="390" fill="url(#hero-orb)" />
        <g class="hero-rings" transform="translate(1050 432)">
          <circle r="245" />
          <ellipse rx="330" ry="126" transform="rotate(-18)" />
          <ellipse rx="176" ry="328" transform="rotate(32)" />
          <path d="M-310 84C-130-170 132-210 310-42" />
        </g>
        <g class="hero-nodes">
          <circle cx="813" cy="370" r="8" /><circle cx="1130" cy="196" r="8" /><circle cx="1300" cy="474" r="8" />
          <circle cx="1015" cy="670" r="8" /><circle cx="930" cy="307" r="4" /><circle cx="1190" cy="586" r="4" />
        </g>
        <path class="hero-beam" d="M604 766C842 584 895 356 1234 106" stroke="url(#hero-line)" />
      </svg>
      <span class="hero-coordinate hero-coordinate-a">52.2297° N / 21.0122° E</span>
      <span class="hero-coordinate hero-coordinate-b">OPEN SYSTEMS · 2026</span>
    </div>
    <div class="hero-copy">
      <p class="hero-brand">Wiesław Šoltés <span>Independent open-source engineer</span></p>
      <h1 id="hero-title">Building the<br /><em>open desktop.</em></h1>
      <p class="hero-intro">GPU renderers, portable UI frameworks, and the controls that turn them into real tools.</p>
      <div class="hero-actions">
        <a class="button-primary" href="#work">Explore the work <span aria-hidden="true">↓</span></a>
        <a class="text-link" href="https://github.com/wieslawsoltes" target="_blank" rel="noreferrer">Follow on GitHub <span>↗</span></a>
      </div>
    </div>
    <div class="hero-status">
      <span class="status-dot"></span>
      <span>Building in public</span>
    </div>
    <a class="hero-scroll" href="#spotlight" aria-label="Scroll to selected projects"><span></span></a>
  </section>

  <SystemsMap />

  <section class="manifesto section-shell" id="about">
    <p class="section-label" data-reveal>What connects the work</p>
    <div class="manifesto-grid">
      <h2 data-reveal>One ecosystem.<br />Many layers.</h2>
      <div class="manifesto-copy" data-reveal>
        <p>I build the infrastructure behind ambitious .NET desktop software: from pixels and text, through layout and controls, to complete editing environments.</p>
        <p>Each project is independent. Together, they form an experiment in what an open, portable desktop stack can become.</p>
      </div>
    </div>
    <div class="layer-line" data-reveal aria-label="Project layers">
      <span>GPU</span><i></i><span>Rendering</span><i></i><span>Frameworks</span><i></i><span>Controls</span><i></i><span>Tools</span>
    </div>
  </section>

  <section class="spotlight" id="spotlight">
    <div class="spotlight-intro section-shell" data-reveal>
      <p class="section-label">Current focus</p>
      <p>Five projects pushing the portable .NET desktop forward.</p>
    </div>
    {spotlights.map((project, index) => (
      <article class="spotlight-project" style={`--project-accent:${project.accent}`}>
        <div class="spotlight-visual" data-reveal>
          <ProjectGlyph slug={project.slug} accent={project.accent} large />
          <span class="spotlight-index">0{index + 1}</span>
        </div>
        <div class="spotlight-copy section-shell" data-reveal>
          <div>
            <p class="project-kicker">{project.eyebrow}</p>
            <h3>{project.name}</h3>
          </div>
          <div class="spotlight-detail">
            <p>{project.statement}</p>
            <a href={projectUrl(project, base)}>View project <span>↗</span></a>
          </div>
        </div>
      </article>
    ))}
  </section>

  <ProjectIndex />

  <ArchiveIndex />

  <section class="principles section-shell">
    <div class="section-heading" data-reveal>
      <p class="section-label">Working principles</p>
      <h2>Deep systems.<br />Practical outcomes.</h2>
    </div>
    <div class="principle-list">
      <article data-reveal><span>01</span><h3>Own the stack</h3><p>Understand the path from input to pixels, then make each layer observable and replaceable.</p></article>
      <article data-reveal><span>02</span><h3>Compatibility matters</h3><p>Move established programming models forward without discarding the knowledge encoded in existing applications.</p></article>
      <article data-reveal><span>03</span><h3>Open by default</h3><p>Build in public, document the seams, and leave behind reusable foundations instead of isolated demos.</p></article>
    </div>
  </section>
</BaseLayout>
