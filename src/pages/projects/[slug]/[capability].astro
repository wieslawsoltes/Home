---
import { Code } from 'astro-expressive-code/components';
import { render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectGlyph from '@/components/ProjectGlyph.astro';
import {
  capabilityFromEntry,
  capabilityPackageUrl,
  capabilityUrl,
  getCapabilities,
  getCapabilityEntries,
  getProjects,
  githubUrl,
  projectUrl,
  type Capability,
  type CapabilityEntry
} from '@/lib/content';

export async function getStaticPaths() {
  const entries = await getCapabilityEntries();
  return entries.map((entry) => {
    const capability = capabilityFromEntry(entry);
    return {
      params: { slug: capability.projectSlug, capability: capability.slug },
      props: { entry }
    };
  });
}

interface Props { entry: CapabilityEntry; }

const { entry } = Astro.props as Props;
const { Content } = await render(entry);
const capability = capabilityFromEntry(entry);
const [projects, capabilities] = await Promise.all([getProjects(), getCapabilities()]);
const project = projects.find((candidate) => candidate.slug === capability.projectSlug);
if (!project) throw new Error(`Unknown capability project: ${capability.projectSlug}`);
const base = import.meta.env.BASE_URL;
const related = (capability.related ?? [])
  .map((id) => capabilities.find((item) => item.id === id))
  .filter((item): item is Capability => Boolean(item));
const primaryPackage = capability.packages[0];
const isToolInstall = capability.install.startsWith('dotnet tool');
const isSourceInstall = capability.install.startsWith('git clone');
const packageReference = `<PackageReference Include="${primaryPackage.name}" Version="VERSION" />`;
const centralPackage = `<PackageVersion Include="${primaryPackage.name}" Version="VERSION" />`;
const installVariants = isToolInstall || isSourceInstall
  ? [{ label: isSourceInstall ? 'Source' : 'CLI', language: 'bash', code: capability.install, title: 'Terminal', frame: 'terminal' }]
  : [
      { label: 'CLI', language: 'bash', code: capability.install, title: 'Terminal', frame: 'terminal' },
      { label: 'PackageReference', language: 'xml', code: packageReference, title: 'Project.csproj', frame: 'code' },
      { label: 'Central package', language: 'xml', code: centralPackage, title: 'Directory.Packages.props', frame: 'code' }
    ];
const usageTitles = {
  csharp: 'QuickStart.cs',
  xml: 'MainWindow.axaml',
  bash: 'Terminal',
  javascript: 'quick-start.js'
} as const;
const usageTitle = capability.usageTitle ?? usageTitles[capability.usageLanguage];
const usageFrame = capability.usageLanguage === 'bash' ? 'terminal' : 'code';
const repoRoot = githubUrl(project);
const branch = project.branch ?? 'main';
const sourceUrl = `${repoRoot}/tree/${branch}/${capability.sourcePath}`;
const docsUrl = capability.docsPath ? `${repoRoot}/blob/${branch}/${capability.docsPath}` : `${repoRoot}#readme`;
const projectMedia = project.media.find((media) => !new URL(media.src).pathname.toLowerCase().endsWith('.svg')) ?? {
  src: `https://opengraph.githubassets.com/portfolio-${project.slug}/wieslawsoltes/${project.repo}`,
  alt: `${project.name} GitHub repository preview`
};
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const siteHome = new URL(base, Astro.site);
const projectUrlAbsolute = new URL(`projects/${project.slug}/`, siteHome);
const softwareId = `${canonicalUrl.href}#software`;
const languageNames = { csharp: 'C#', xml: 'XAML', bash: 'Shell', javascript: 'JavaScript' } as const;
const structuredData = [
  {
    '@type': 'SoftwareSourceCode',
    '@id': softwareId,
    name: `${capability.name} — ${project.name}`,
    description: capability.description,
    url: canonicalUrl.href,
    codeRepository: sourceUrl,
    author: { '@id': `${siteHome.href}#person` },
    maintainer: { '@id': `${siteHome.href}#person` },
    programmingLanguage: languageNames[capability.usageLanguage],
    runtimePlatform: '.NET',
    genre: project.category,
    isAccessibleForFree: true,
    isPartOf: { '@id': `${projectUrlAbsolute.href}#software` },
    keywords: [capability.name, project.name, ...capability.highlights, ...capability.packages.map((item) => item.name)].join(', ')
  },
  {
    '@type': 'BreadcrumbList',
    '@id': `${canonicalUrl.href}#breadcrumb`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Projects', item: siteHome.href },
      { '@type': 'ListItem', position: 2, name: project.name, item: projectUrlAbsolute.href },
      { '@type': 'ListItem', position: 3, name: capability.name, item: canonicalUrl.href }
    ]
  }
];
---

<BaseLayout
  title={`${capability.name} · ${project.name}`}
  description={capability.description}
  image={projectMedia?.src}
  imageAlt={projectMedia?.alt}
  structuredData={structuredData}
>
  <article class="capability-page" style={`--project-accent:${project.accent}`} data-primary-package={primaryPackage.name}>
    <header class="capability-hero">
      <div class="capability-hero-mark" aria-hidden="true">
        <ProjectGlyph slug={project.slug} accent={project.accent} large />
      </div>
      <div class="section-shell capability-hero-inner">
        <nav class="capability-breadcrumb" aria-label="Breadcrumb">
          <a href={`${base}#work`}>Projects</a><span>/</span>
          <a href={projectUrl(project, base)}>{project.name}</a><span>/</span>
          <strong>{capability.name}</strong>
        </nav>
        <div class="capability-title-grid">
          <div>
            <p class="project-kicker">{capability.eyebrow}</p>
            <h1 data-transition-title={`capability-title-${capability.projectSlug}-${capability.slug}`}>{capability.name}</h1>
          </div>
          <div class="capability-lede">
            <p>{capability.statement}</p>
            <a class="button-primary" href={sourceUrl} target="_blank" rel="noreferrer">Explore source <span>↗</span></a>
          </div>
        </div>
        <div class="capability-meta">
          <div><span>Parent system</span><strong>{project.name}</strong></div>
          <div><span>Status</span><strong><i class="status-dot"></i>{capability.status}</strong></div>
          <div><span>Modules</span><strong>{capability.packages.length}</strong></div>
          <div><span>Repository</span><strong>{project.repo}/{capability.sourcePath.split('/').at(-1)}</strong></div>
        </div>
      </div>
    </header>

    <section class="capability-overview section-shell">
      <div data-reveal>
        <p class="section-label">Capability</p>
        <Content />
      </div>
      <ol data-reveal>
        {capability.highlights.map((highlight, index) => (
          <li><span>{String(index + 1).padStart(2, '0')}</span><p>{highlight}</p></li>
        ))}
      </ol>
    </section>

    <section class="architecture capability-architecture section-shell">
      <div class="section-heading compact" data-reveal>
        <p class="section-label">How it composes</p>
        <h2>From intent<br />to working system.</h2>
      </div>
      <div class="architecture-flow">
        {capability.layers.map((item, index) => (
          <article data-reveal>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{item.label}</h3>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="quickstart section-shell">
      <div class="section-heading" data-reveal>
        <p class="section-label">Quick start</p>
        <h2>Adopt this<br />capability.</h2>
        <p>Start with the primary module, then add the related packages only when the application needs those layers. Replace <code>VERSION</code> with the current NuGet version.</p>
      </div>
      <div class="code-stack">
        <article class="code-example install-example" data-reveal data-code-tabs>
          <header class="code-example-toolbar">
            <span>01 · Install</span>
            <div class="code-tabs" role="tablist" aria-label="Installation format">
              {installVariants.map((variant, index) => (
                <button
                  id={`install-tab-${capability.projectSlug}-${capability.slug}-${index}`}
                  type="button"
                  role="tab"
                  aria-controls={`install-pane-${capability.projectSlug}-${capability.slug}-${index}`}
                  aria-selected={index === 0 ? 'true' : 'false'}
                  tabindex={index === 0 ? 0 : -1}
                  data-code-tab={index}
                >{variant.label}</button>
              ))}
            </div>
          </header>
          {installVariants.map((variant, index) => (
            <div
              id={`install-pane-${capability.projectSlug}-${capability.slug}-${index}`}
              role="tabpanel"
              aria-labelledby={`install-tab-${capability.projectSlug}-${capability.slug}-${index}`}
              data-code-pane={index}
              hidden={index !== 0}
            >
              <Code
                code={variant.code}
                lang={variant.language}
                title={variant.title}
                frame={variant.frame as 'code' | 'terminal'}
                class="portfolio-code"
              />
            </div>
          ))}
        </article>
        <article class="code-example" data-reveal>
          <div class="code-example-toolbar"><span>02 · Use · {capability.usageLanguage}</span></div>
          <Code
            code={capability.usage}
            lang={capability.usageLanguage}
            title={usageTitle}
            frame={usageFrame}
            mark={capability.usageMark}
            ins={capability.usageInsertions}
            del={capability.usageDeletions}
            class="portfolio-code"
          />
        </article>
      </div>
    </section>

    <section class="packages capability-packages section-shell">
      <div class="section-heading compact" data-reveal>
        <p class="section-label">Modules in this capability</p>
        <h2>Use one layer.<br />Compose the rest.</h2>
      </div>
      <div class="package-list">
        {capability.packages.map((item, index) => (
          <a href={capabilityPackageUrl(item)} target="_blank" rel="noreferrer" data-package={item.name} data-reveal>
            <span class="package-number">{String(index + 1).padStart(2, '0')}</span>
            <strong>{item.name}</strong>
            <p>{item.note}</p>
            <small data-package-version></small>
            <span class="package-arrow">↗</span>
          </a>
        ))}
      </div>
    </section>

    {related.length > 0 && (
      <section class="capability-related section-shell">
        <div class="section-heading compact" data-reveal>
          <p class="section-label">Inside {project.name}</p>
          <h2>Continue through<br />the product family.</h2>
        </div>
        <div class="capability-card-grid">
          {related.map((item) => (
            <a href={capabilityUrl(item, base)} data-reveal>
              <span>{item.eyebrow}</span><strong data-transition-title={`capability-title-${item.projectSlug}-${item.slug}`}>{item.name}</strong><p>{item.description}</p><i>→</i>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="source-cta section-shell" data-reveal>
      <p class="section-label">Source of truth</p>
      <h2>Read the module beside the complete system.</h2>
      <p>The implementation, samples, issues, and release notes stay in the parent repository so module details remain connected to the product architecture.</p>
      <div class="resource-links">
        <a href={projectUrl(project, base)}>Project overview <span>←</span></a>
        <a href={sourceUrl} target="_blank" rel="noreferrer">Module source <span>↗</span></a>
        <a href={docsUrl} target="_blank" rel="noreferrer">Documentation <span>↗</span></a>
        <a href={`${repoRoot}/issues`} target="_blank" rel="noreferrer">Issues <span>↗</span></a>
      </div>
    </section>

    <a class="next-project capability-parent-return" href={projectUrl(project, base)} style={`--next-accent:${project.accent}`}>
      <span class="section-label">Return to product family</span>
      <strong>{project.name}</strong>
      <span class="next-arrow">←</span>
    </a>
  </article>
</BaseLayout>
