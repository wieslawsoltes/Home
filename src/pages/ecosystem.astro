---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SystemsMap from '@/components/SystemsMap.astro';
import { getProjects, projectUrl } from '@/lib/content';

const base = import.meta.env.BASE_URL;
const projects = await getProjects();
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ecosystemId = `${canonicalUrl.href}#projects`;
const structuredData = {
  '@type': 'ItemList',
  '@id': ecosystemId,
  name: 'Wiesław Šoltés open-source project ecosystem',
  numberOfItems: projects.length,
  itemListElement: projects.map((project, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: project.name,
    url: new URL(projectUrl(project, base), Astro.site).href
  }))
};
---

<BaseLayout
  title="Open desktop ecosystem"
  description="An interactive map of Wiesław Šoltés’s open-source graphics, framework, control, diagnostics, and application projects."
  pageType="CollectionPage"
  structuredData={structuredData}
>
  <header class="editorial-hero section-shell">
    <p class="section-label">The ecosystem</p>
    <h1>Independent parts.<br /><em>Compounding value.</em></h1>
    <p>{projects.length} detailed projects trace a path from GPU devices and text layout to UI frameworks, controls, diagnostics, and complete authoring environments.</p>
  </header>
  <SystemsMap />
  <section class="ecosystem-notes section-shell">
    <article data-reveal><span>01</span><h2>Foundation</h2><p>ProGPU, Svg.Skia, Pretext, and Effector own the lower rendering and content-preparation layers.</p></article>
    <article data-reveal><span>02</span><h2>Compatibility</h2><p>LibreWPF, LibreWinForms, and alternative Avalonia backends test how established UI models can move onto portable infrastructure.</p></article>
    <article data-reveal><span>03</span><h2>Productivity</h2><p>Dock, grids, graph controls, HtmlML, XAML tools, Inspector, CDP Test Studio, and DevToolsUno make complex applications buildable, testable, and observable.</p></article>
    <article data-reveal><span>04</span><h2>Applications</h2><p>ProEdit, ProCad, DxfParser, CodexGui, XamlPlayground, Core2D, and XamlVisualEditor prove the layers in complete working environments.</p></article>
  </section>
</BaseLayout>
